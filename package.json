{
  "name": "ball-fight-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/serve.mjs",
    "test": "node tests/regression.mjs && node tests/uiContracts.mjs && node tests/profileVersionReset.mjs",
    "check": "node scripts/checkSyntax.mjs",
    "hunting:elite-combinations": "node scripts/generateEliteMobCombinations.mjs",
    "train": "node scripts/rl/train.mjs",
    "benchmark": "node scripts/benchmark.mjs",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.mjs\" \"scripts/**/*.mjs\" \"*.html\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.mjs\" \"scripts/**/*.mjs\" \"*.html\""
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0"
  }
}
